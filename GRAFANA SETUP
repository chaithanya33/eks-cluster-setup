through script setup



echo "📦 Installing Helm..."

if ! command -v helm &> /dev/null
then
  curl https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash
fi

helm version

echo "📁 Creating namespace..."

kubectl create namespace $NAMESPACE || true

echo "📡 Adding Prometheus repo..."

helm repo add prometheus-community https://prometheus-community.github.io/helm-charts
helm repo update

echo "📊 Installing kube-prometheus-stack..."

helm install monitoring prometheus-community/kube-prometheus-stack -n $NAMESPACE

echo "⏳ Waiting for pods to be ready..."
sleep 60

kubectl wait --for=condition=Ready pods --all -n $NAMESPACE --timeout=300s

echo "🌐 Exposing Grafana via LoadBalancer..."

kubectl patch svc monitoring-grafana -n $NAMESPACE \
  -p '{"spec": {"type": "LoadBalancer"}}'

echo "⏳ Waiting for LoadBalancer IP..."

while true; do
  LB=$(kubectl get svc monitoring-grafana -n $NAMESPACE -o jsonpath='{.status.loadBalancer.ingress[0].hostname}')
  if [ -n "$LB" ]; then
    break
  fi
  echo "Waiting for external IP..."
  sleep 10
done

echo "🔐 Fetching Grafana password..."

PASSWORD=$(kubectl get secret monitoring-grafana -n $NAMESPACE -o jsonpath="{.data.admin-password}" | base64 --decode)

echo "=================================================="
echo "🎉 SETUP COMPLETE!"
echo "=================================================="
echo "🌍 Grafana URL: http://$LB"
echo "👤 Username: admin"
echo "🔑 Password: $PASSWORD"
echo "=================================================="
